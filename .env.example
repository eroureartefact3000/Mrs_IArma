# =============================================================================
# Mrs IArma · The Cannes Oracle — environment configuration
#
# Copy this file to `.env` and fill in the two required keys at the top.
# In production, inject these via your secret manager (GCP Secret Manager,
# AWS Secrets Manager, Doppler, etc.) — never commit the populated .env.
# =============================================================================

# ---- REQUIRED -----------------------------------------------------------------
# Anthropic Claude API key (used by VLM extraction + LLM-judge).
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key (used for embeddings + RAG retrieval).
VOYAGE_API_KEY=pa-...


# ---- Service identity ---------------------------------------------------------
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development

# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ---- Auth (frontend → backend) ------------------------------------------------
# Shared secret expected in the X-API-Key header. Empty disables auth.
# Recommended only in local dev. In production set a strong random value AND
# inject the same value into the frontend build as VITE_API_KEY.
API_KEY=


# ---- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed origins.
# Use "*" only in local dev. In production, use a strict list:
#   ALLOWED_ORIGINS=https://oracle.yourdomain.com,https://staging.yourdomain.com
ALLOWED_ORIGINS=*


# ---- Rate limiting (per IP, sliding window) -----------------------------------
# Set either to 0 to disable that window.
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=60


# ---- Daily cost cap -----------------------------------------------------------
# Hard cap on the number of evaluations per UTC day across all IPs. The 0
# default means unlimited. For a public site, set this to something like 200
# to bound API spend (1 evaluation ~ $2).
DAILY_EVALUATION_CAP=0


# ---- Pipeline tuning ----------------------------------------------------------
# JUDGE_PASSES: number of parallel LLM-judge passes (averaged). Don't drop
# below 2 — variance gets unacceptable. Don't push above 5 — diminishing returns.
JUDGE_PASSES=3

# RAG_TOP_K: how many winner references are retrieved per evaluation. 2 extra
# non-winners are always added on top to keep the judge honest.
RAG_TOP_K=5


# ---- Upload limits ------------------------------------------------------------
# Per-file size cap in MB. Accepted formats: jpg, jpeg, png, webp, avif, gif, pdf.
# Hard ceiling enforced by the schema is 50 MB.
MAX_UPLOAD_MB=25


# ---- Static frontend ----------------------------------------------------------
# When true, FastAPI serves a static frontend bundle at /.
# Preference order: $FRONTEND_DIR → frontend/dist → mini_frontend.
# Set to false for pure-API deployments where the frontend is on a separate
# CDN (Firebase Hosting, Cloud CDN, Vercel, …).
SERVE_FRONTEND=true

# Optional explicit override. Absolute path or repo-relative. Empty = auto-detect.
FRONTEND_DIR=


# =============================================================================
# Frontend build-time variables (consumed by Vite — must be prefixed VITE_)
# These are NOT read by the API service. Set them in your frontend deploy
# environment (Firebase, Vercel) OR inline at build time:
#   VITE_API_KEY=$API_KEY pnpm build
# =============================================================================
# VITE_API_KEY=
